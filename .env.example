# Environment Configuration for Vehicle Order Tracker

# =============================================================================
# LOCAL DEVELOPMENT SETUP
# =============================================================================
# Run: npm run dev (client) and npm run server (API server)

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
# PORT - Server port, defaults to 8080 (optional)
# PORT=8080
# FIREBASE_PROJECT_ID=vehicles-in-need

# =============================================================================
# UNSECURED ORDER REMINDER JOB
# =============================================================================
# Cloud Run exposes /jobs/unsecured-order-reminders when enabled.
# Google Apps Script calls this job daily, sends due emails, then acknowledges
# successful sends so each active order waits the configured number of days.
# UNSECURED_REMINDERS_ENABLED=true
# UNSECURED_REMINDER_EVERY_DAYS=3
# UNSECURED_REMINDER_MAX_PER_RUN=50
# PUBLIC_APP_URL=https://pre-order-dealer-exchange-tracker-842946218691.us-west1.run.app
# UNSECURED_REMINDER_KEY is injected from Secret Manager in Cloud Run.

# =============================================================================
# MANAGER ORDER NOTIFICATION JOB
# =============================================================================
# Cloud Run exposes /jobs/order-notifications when enabled.
# Google Apps Script calls this job every 5 minutes for new-order manager emails,
# and weekly on Monday morning for the manager digest. Recipients are active
# users marked as Manager in the app.
# ORDER_NOTIFICATIONS_ENABLED=true
# ORDER_NOTIFICATION_MAX_PER_RUN=25
# ORDER_NOTIFICATION_START_AT=2026-07-07T15:55:15Z
# ORDER_NOTIFICATION_KEY is injected from Secret Manager in Cloud Run.
# Apps Script must set ORDER_NOTIFICATION_API_KEY to the same secret value.

# =============================================================================
# FIREBASE CONFIGURATION (if needed)
# =============================================================================
# Firebase configuration is typically embedded in the frontend bundle
# No environment variables needed for Firebase client SDK
